-- ========== 基礎功能實現 ==========
local FlyBodyVelocity = nil
local FlyBodyGyro = nil

local function updateFly()
	if not ExtraToggles.Fly then
		if ExtraConnections.Fly then ExtraConnections.Fly:Disconnect(); ExtraConnections.Fly = nil end
		if FlyBodyVelocity then FlyBodyVelocity:Destroy(); FlyBodyVelocity = nil end
		if FlyBodyGyro then FlyBodyGyro:Destroy(); FlyBodyGyro = nil end
		local hum = getHumanoid(LocalPlayer)
		if hum then hum.PlatformStand = false end
		return
	end
	if ExtraConnections.Fly then return end
	local root = getHRP(LocalPlayer)
	local hum = getHumanoid(LocalPlayer)
	if not root or not hum then return end

	FlyBodyVelocity = Instance.new("BodyVelocity")
	FlyBodyVelocity.MaxForce = Vector3.new(1e9, 1e9, 1e9)
	FlyBodyVelocity.Parent = root
	FlyBodyGyro = Instance.new("BodyGyro")
	FlyBodyGyro.MaxTorque = Vector3.new(1e9, 1e9, 1e9)
	FlyBodyGyro.P = 10000
	FlyBodyGyro.D = 1000
	FlyBodyGyro.Parent = root

	hum.PlatformStand = true
	local PlayerModule = nil
	pcall(function()
		PlayerModule = require(LocalPlayer.PlayerScripts:WaitForChild("PlayerModule"))
	end)

	ExtraConnections.Fly = RunService.RenderStepped:Connect(function()
		local currentRoot = getHRP(LocalPlayer)
		local currentHum = getHumanoid(LocalPlayer)
		if not currentRoot or not currentHum then return end
		if FlyBodyVelocity.Parent ~= currentRoot then FlyBodyVelocity.Parent = currentRoot end
		if FlyBodyGyro.Parent ~= currentRoot then FlyBodyGyro.Parent = currentRoot end
		currentHum.PlatformStand = true

		local moveVector = Vector3.new()
		if PlayerModule then
			local controls = PlayerModule:GetControls()
			moveVector = controls:GetMoveVector()
		else
			moveVector = currentHum.MoveDirection
		end
		local cam = workspace.CurrentCamera
		local forward = cam.CFrame.LookVector
		local right = cam.CFrame.RightVector
		local upDown = 0
		if UserInputService:IsKeyDown(Enum.KeyCode.Space) then upDown = 1 end
		if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then upDown = -1 end

		local velocity = (forward * -moveVector.Z + right * moveVector.X)
		if velocity.Magnitude > 0 or upDown ~= 0 then
			FlyBodyVelocity.Velocity = (velocity * ExtraToggles.FlySpeed) + Vector3.new(0, upDown * ExtraToggles.FlySpeed, 0)
		else
			FlyBodyVelocity.Velocity = Vector3.new(0, 0, 0)
		end
		FlyBodyGyro.CFrame = cam.CFrame
	end)
end


local function startCSync()
    local hrp = getHRP(LocalPlayer)
    if not hrp then return end
    if VoidFramework.csyncConnection then return end
    VoidFramework.csyncConnection = RunService.Heartbeat:Connect(function()
        local hrp = getHRP(LocalPlayer)
        if not hrp then return end
        local realCF = hrp.CFrame
        local offset = getDesyncOffset()
        hrp.CFrame = CFrame.new(offset)
        RunService.RenderStepped:Wait()
        hrp.CFrame = realCF
    end)
end

local function stopCSync()
    if VoidFramework.csyncConnection then
        VoidFramework.csyncConnection:Disconnect()
        VoidFramework.csyncConnection = nil
    end
end

local function updateVoid(dt)
    if not VoidFramework.voidActive then return end
    local S = VoidFramework.settings
    if tick() - VoidFramework.lastSwitch < S.switchSpeed then return end
    VoidFramework.lastSwitch = tick()
    VoidFramework.currentVoidIndex = (VoidFramework.currentVoidIndex % #deepVoidPositions) + 1
end


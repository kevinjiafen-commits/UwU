local function loadEmotePack(packName)
    for _, child in ipairs(scrollFrame:GetChildren()) do if child:IsA("TextButton") then child:Destroy() end end
    for _, emoteData in ipairs(emotePacks[packName]) do
        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(1, -10, 0, 16) -- 縮小按鈕高度
        btn.BackgroundColor3 = Color3.fromRGB(40, 40, 45)
        btn.Text = emoteData.name
        btn.TextColor3 = Color3.fromRGB(220, 220, 220)
        btn.Font = Enum.Font.Gotham
        btn.TextSize = 9 -- 縮小字體
        btn.Parent = scrollFrame
        Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 4)
        
        btn.MouseButton1Click:Connect(function()
            btn.BackgroundColor3 = Color3.fromRGB(100, 150, 255)
            task.wait(0.1)
            btn.BackgroundColor3 = Color3.fromRGB(40, 40, 45)
            playCustomEmote(emoteData.speed, emoteData.style)
        end)
    end
end

for packName, _ in pairs(emotePacks) do
    local packBtn = Instance.new("TextButton")
    packBtn.Size = UDim2.new(1, -10, 0, 18) -- 縮小按鈕高度
    packBtn.BackgroundColor3 = Color3.fromRGB(50, 50, 60)
    packBtn.Text = packName
    packBtn.TextColor3 = Color3.fromRGB(255, 200, 100)
    packBtn.Font = Enum.Font.GothamBold
    packBtn.TextSize = 9 -- 縮小字體
    packBtn.Parent = packsScroll
    Instance.new("UICorner", packBtn).CornerRadius = UDim.new(0, 4)
    
    packBtn.MouseButton1Click:Connect(function()
        stopCustomEmote() 
        loadEmotePack(packName)
        titleLabel.Text = "kevin v3: " .. packName
        packsFrame.Visible = false 
    end)
end


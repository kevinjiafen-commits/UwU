local allowedBodyParts = {
    ["Head"]=true, ["Torso"]=true, ["UpperTorso"]=true, ["LowerTorso"]=true,
    ["Left Arm"]=true, ["Right Arm"]=true, ["Left Leg"]=true, ["Right Leg"]=true,
    ["LeftUpperArm"]=true, ["LeftLowerArm"]=true, ["LeftHand"]=true,
    ["RightUpperArm"]=true, ["RightLowerArm"]=true, ["RightHand"]=true,
    ["LeftUpperLeg"]=true, ["LeftLowerLeg"]=true, ["LeftFoot"]=true,
    ["RightUpperLeg"]=true, ["RightLowerLeg"]=true, ["RightFoot"]=true
}

local function isValidPart(part)
    if not part:IsA("BasePart") then return false end
    if allowedBodyParts[part.Name] then return true end
    if part.Parent and part.Parent:IsA("Accessory") and part.Name == "Handle" then return true end
    return false
end

local function getCharacterParts(character)
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    if not rootPart then return nil end
    local partsInfo = { RootPart = rootPart, Pieces = {} }
    character.Archivable = true
    
    for _, child in ipairs(character:GetDescendants()) do
        if isValidPart(child) then
            child.Archivable = true
            local fakePart = child:Clone()
            for _, subChild in ipairs(fakePart:GetDescendants()) do
                if subChild:IsA("JointInstance") or subChild:IsA("Script") or subChild:IsA("LocalScript") or subChild:IsA("Constraint") or subChild:IsA("BodyMover") or subChild:IsA("Attachment") then
                    subChild:Destroy()
                end
            end
            fakePart.Name = "EmoteVisual_" .. child.Name
            fakePart.Anchored = true
            fakePart.CanCollide = false
            fakePart.CanQuery = false 
            fakePart.Massless = true
            fakePart.CastShadow = false
            fakePart.Parent = fakePartsFolder
            
            -- 套用材質
            fakePart.Material = isNeonGlitchMode and Enum.Material.Neon or (customMatList[currentMatIndex].mat or fakePart.Material)

            local a0 = Instance.new("Attachment", fakePart)
            a0.Position = Vector3.new(0, fakePart.Size.Y/2, 0)
            local a1 = Instance.new("Attachment", fakePart)
            a1.Position = Vector3.new(0, -fakePart.Size.Y/2, 0)
            
            local trail = Instance.new("Trail", fakePart)
            trail.Attachment0 = a0
            trail.Attachment1 = a1
            trail.Enabled = isTrailsMode
            trail.Lifetime = 0.4
            trail.LightEmission = 0.8
            trail.Transparency = NumberSequence.new({NumberSequenceKeypoint.new(0,0), NumberSequenceKeypoint.new(1,1)})
            trail.Color = ColorSequence.new(fakePart.Color)
            
            local emitter = Instance.new("ParticleEmitter", fakePart)
            emitter.Enabled = isGhostMode or isNeonGlitchMode
            emitter.Rate = 15
            emitter.Speed = NumberRange.new(1, 3)
            emitter.Lifetime = NumberRange.new(0.5, 1)
            emitter.Size = NumberSequence.new({NumberSequenceKeypoint.new(0,0.5), NumberSequenceKeypoint.new(1,0)})
            emitter.Transparency = NumberSequence.new({NumberSequenceKeypoint.new(0,0.5), NumberSequenceKeypoint.new(1,1)})
            
            table.insert(partsInfo.Pieces, {
                realPart = child,
                fakePart = fakePart,
                trail = trail,
                emitter = emitter,
                physicsSeed = chaoticSeed + #partsInfo.Pieces * 13, 
                spinAxis = Vector3.new(math.random(-100,100), math.random(-100,100), math.random(-100,100)).Unit,
                originalMaterial = child.Material,
                originalColor = fakePart.Color
            })
        end
    end
    return partsInfo
end

local function playCustomEmote(baseSpeed, style)
    if not targetPlayer.Character then return end
    if not isCustomEmoteActive then
        fakePartsFolder:ClearAllChildren()
        characterParts = getCharacterParts(targetPlayer.Character)
        if not characterParts then return end
        isCustomEmoteActive = true
    end
    currentRotationSpeed = baseSpeed
    currentEmoteStyle = style
    rotationAngle = 0
    chaoticSeed = tick() 
end

local function stopCustomEmote()
    isCustomEmoteActive = false
    currentRotationSpeed = 0
    if characterParts then
        for _, info in ipairs(characterParts.Pieces) do
            if info.realPart and info.realPart.Parent then info.realPart.LocalTransparencyModifier = 0 end
        end
        characterParts = nil
    end
    fakePartsFolder:ClearAllChildren()
    -- 還原鏡頭 FOV
    workspace.CurrentCamera.FieldOfView = 70
end


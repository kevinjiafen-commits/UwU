local function getClosestPlayer(d, maxDist)
	local cd = d or math.huge; local cp = nil
	local mp = getHRP(LocalPlayer) and getHRP(LocalPlayer).Position
	if not mp then return nil end
	for _,p in ipairs(Players:GetPlayers()) do 
		if p~=LocalPlayer then
			if ExtraToggles.AimbotTeamCheck and p.Team == LocalPlayer.Team then continue end
			local h = getHRP(p); if h then
				local dist = (h.Position - mp).Magnitude
				if maxDist and dist > maxDist then continue end
				if dist < cd then cd, cp = dist, p end
			end
		end 
	end
	return cp
end

local TargetBones = {"Head", "UpperTorso", "LowerTorso", "HumanoidRootPart", "LeftUpperArm", "RightUpperArm", "LeftUpperLeg", "RightUpperLeg"}
local function getTargetPart(character, isAimbot)
    local useRandomizer = isAimbot and ExtraToggles.AimbotBoneRandomizer or (not isAimbot and ExtraToggles.SilentBoneRandomizer)
    local partName = isAimbot and ExtraToggles.AimbotTargetPart or nil
    if useRandomizer then
        local validBones = {}
        for _, b in ipairs(TargetBones) do
            if character:FindFirstChild(b) then table.insert(validBones, character[b]) end
        end
        if #validBones > 0 then return validBones[math.random(1, #validBones)] end
    end
    if partName then
        local chosen = character:FindFirstChild(partName)
        if chosen then return chosen end
    end
    local defaultPart = (isAimbot and ExtraToggles.AimbotPart) or (not isAimbot and ExtraToggles.SilentAimPart) and "Head" or "HumanoidRootPart"
    return character:FindFirstChild(defaultPart)
end


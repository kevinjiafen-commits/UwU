local function update2DBoxes()
    if not Drawing then return end
    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end
        local char = player.Character
        local root = getHRP(player)
        local hum = getHumanoid(player)
        if not char or not root or not hum then
            if Box2DObjects[player] then for _, line in ipairs(Box2DObjects[player]) do line:Remove() end Box2DObjects[player] = nil end
            continue
        end
        local dist = (root.Position - Camera.CFrame.Position).Magnitude
        if ExtraToggles.ESPFilterMaxDistance > 0 and dist > ExtraToggles.ESPFilterMaxDistance then
            if Box2DObjects[player] then for _, line in ipairs(Box2DObjects[player]) do line.Visible = false end end
            continue
        end
        if ExtraToggles.ESPFilterMinHealth > 0 and hum.Health < ExtraToggles.ESPFilterMinHealth then
            if Box2DObjects[player] then for _, line in ipairs(Box2DObjects[player]) do line.Visible = false end end
            continue
        end
        if not ExtraToggles.Box2DEnabled then
            if Box2DObjects[player] then for _, line in ipairs(Box2DObjects[player]) do line.Visible = false end end
            continue
        end
        local head = char:FindFirstChild("Head")
        if not head then continue end
        local headTop = head.Position + Vector3.new(0, 1, 0)
        local foot = root.Position - Vector3.new(0, 2.5, 0)
        local headPos, headOnScreen = Camera:WorldToViewportPoint(headTop)
        local footPos, footOnScreen = Camera:WorldToViewportPoint(foot)
        if not headOnScreen or not footOnScreen then
            if Box2DObjects[player] then for _, line in ipairs(Box2DObjects[player]) do line.Visible = false end end
            continue
        end
        local width = (headPos.Y - footPos.Y) * 0.35
        local tl = Vector2.new(headPos.X - width/2, headPos.Y)
        local tr = Vector2.new(headPos.X + width/2, headPos.Y)
        local bl = Vector2.new(footPos.X - width/2, footPos.Y)
        local br = Vector2.new(footPos.X + width/2, footPos.Y)
        if not Box2DObjects[player] then
            local lines = {}
            for i = 1, 4 do
                local line = Drawing.new("Line")
                line.Color = ExtraToggles.Box2DColor
                line.Thickness = ExtraToggles.Box2DThickness
                line.Transparency = 1
                lines[i] = line
            end
            Box2DObjects[player] = lines
        end
        local lines = Box2DObjects[player]
        lines[1].From = tl; lines[1].To = tr
        lines[2].From = tr; lines[2].To = br
        lines[3].From = br; lines[3].To = bl
        lines[4].From = bl; lines[4].To = tl
        for _, line in ipairs(lines) do
            line.Color = ExtraToggles.Box2DColor
            line.Thickness = ExtraToggles.Box2DThickness
            line.Visible = true
        end
    end
end


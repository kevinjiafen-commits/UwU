local function updateOffScreenIndicators()
	if not ExtraToggles.OffScreenIndicators then
		for _, triangle in pairs(OffScreenObjects) do
			if triangle.Remove then triangle:Remove() end
		end
		OffScreenObjects = {}
		return
	end
	for _, player in ipairs(Players:GetPlayers()) do
		if player == LocalPlayer then continue end
		local char = player.Character
		if not char then 
			if OffScreenObjects[player] then OffScreenObjects[player]:Remove(); OffScreenObjects[player] = nil end
			continue 
		end
		local root = getHRP(player)
		if not root then continue end
		local pos, onScreen = Camera:WorldToViewportPoint(root.Position)
		if not onScreen and (getHumanoid(player) and getHumanoid(player).Health > 0) then
			local triangle = OffScreenObjects[player]
			if not triangle then
				if Drawing then
					triangle = Drawing.new("Triangle")
					triangle.Color = Color3.fromRGB(255, 50, 50)
					triangle.Filled = true
					triangle.Thickness = 1
					triangle.Transparency = 1
					OffScreenObjects[player] = triangle
				end
			end
			if triangle then
				local center = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
				local direction = Vector2.new(pos.X - center.X, pos.Y - center.Y).Unit
				local angle = math.atan2(direction.Y, direction.X)
				local radius = ExtraToggles.IndicatorRadius or 150
				local size = ExtraToggles.IndicatorSize or 20
				local pointPos = center + Vector2.new(math.cos(angle) * radius, math.sin(angle) * radius)
				local pointLeft = center + Vector2.new(math.cos(angle - 0.2) * (radius - size), math.sin(angle - 0.2) * (radius - size))
				local pointRight = center + Vector2.new(math.cos(angle + 0.2) * (radius - size), math.sin(angle + 0.2) * (radius - size))
				triangle.PointA = pointPos
				triangle.PointB = pointLeft
				triangle.PointC = pointRight
				triangle.Visible = true
			end
		else
			if OffScreenObjects[player] then OffScreenObjects[player].Visible = false end
		end
	end
end


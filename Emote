-- ========== Target Arrow Tracker 绘制逻辑 ==========
local TargetArrowTriangle = nil
local TargetArrowTextDist = nil
local TargetArrowTextHP = nil

local function updateTargetArrow()
    if TargetArrowTriangle then TargetArrowTriangle.Visible = false end
    if TargetArrowTextDist then TargetArrowTextDist.Visible = false end
    if TargetArrowTextHP then TargetArrowTextHP.Visible = false end
    if not ExtraToggles.TargetArrowEnabled then return end

    local target = nil
    if ExtraToggles.TargetArrowTarget == "Nearest" then
        target = getClosestPlayer()
    else
        for _, p in ipairs(Players:GetPlayers()) do
            if p.Name == ExtraToggles.TargetArrowTarget then target = p; break end
        end
    end
    if not target or not target.Character then return end
    local root = getHRP(target)
    if not root then return end

    local pos, onScreen = Camera:WorldToViewportPoint(root.Position)
    local dir = Vector2.new(pos.X - Camera.ViewportSize.X/2, pos.Y - Camera.ViewportSize.Y/2)
    if dir.Magnitude == 0 then dir = Vector2.new(1,0) end
    dir = dir.Unit
    local radius = ExtraToggles.TargetArrowRadius
    local arrowPos = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2) + dir * radius
    local arrowSize = ExtraToggles.TargetArrowSize
    local angle = math.atan2(dir.Y, dir.X)
    local perpAngle = angle + math.pi/2

    if not TargetArrowTriangle then
        TargetArrowTriangle = Drawing.new("Triangle")
        TargetArrowTriangle.Filled = true
        TargetArrowTriangle.Thickness = 1
        TargetArrowTriangle.Transparency = 1
    end
    TargetArrowTriangle.PointA = arrowPos
    local baseHalf = arrowSize * 0.6
    TargetArrowTriangle.PointB = arrowPos - dir * arrowSize + Vector2.new(math.cos(perpAngle), math.sin(perpAngle)) * baseHalf
    TargetArrowTriangle.PointC = arrowPos - dir * arrowSize - Vector2.new(math.cos(perpAngle), math.sin(perpAngle)) * baseHalf
    TargetArrowTriangle.Color = ExtraToggles.TargetArrowColor
    TargetArrowTriangle.Visible = true

    local dist = math.floor((root.Position - Camera.CFrame.Position).Magnitude)
    local hum = getHumanoid(target)
    local hp = hum and math.floor(hum.Health) or 0
    if not TargetArrowTextDist then
        TargetArrowTextDist = Drawing.new("Text")
        TargetArrowTextDist.Center = true
        TargetArrowTextDist.Outline = true
        TargetArrowTextDist.Size = 14
        TargetArrowTextDist.Visible = false
    end
    TargetArrowTextDist.Text = dist .. "m"
    TargetArrowTextDist.Position = arrowPos + dir * 15
    TargetArrowTextDist.Color = Color3.new(1,1,1)
    TargetArrowTextDist.Visible = true

    if not TargetArrowTextHP then
        TargetArrowTextHP = Drawing.new("Text")
        TargetArrowTextHP.Center = true
        TargetArrowTextHP.Outline = true
        TargetArrowTextHP.Size = 14
        TargetArrowTextHP.Visible = false
    end
    TargetArrowTextHP.Text = hp .. " HP"
    TargetArrowTextHP.Position = arrowPos + dir * 30
    TargetArrowTextHP.Color = Color3.fromRGB(255, 80, 80)
    TargetArrowTextHP.Visible = true
end


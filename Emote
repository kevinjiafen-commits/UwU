-- ========== Silent Aim 性能优化与缓存 ==========
-- ============================================================
local SilentAimCache = {
    targetPlayer = nil,
    hitPart = nil,
    hitSuccess = false,
    lastUpdate = 0
}

local function updateSilentAimCache()
    if not ExtraToggles.SilentAim then
        SilentAimCache.targetPlayer = nil
        SilentAimCache.hitPart = nil
        SilentAimCache.hitSuccess = false
        SilentAimCache.lastUpdate = 0
        return
    end
    local now = tick()
    if now - SilentAimCache.lastUpdate < 0.05 then return end
    SilentAimCache.lastUpdate = now

    local targetPlayer = nil
    local bestValue = math.huge
    local center
    if UserInputService.TouchEnabled then
        center = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
    else
        center = UserInputService:GetMouseLocation()
    end
    local minAngle = ExtraToggles.SilentAimFOV

    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            if ExtraToggles.AimbotTeamCheck and player.Team == LocalPlayer.Team then continue end
            local part = player.Character:FindFirstChild("HumanoidRootPart") or player.Character:FindFirstChild("Head")
            local hum = player.Character:FindFirstChildOfClass("Humanoid")
            if part and hum and hum.Health > 0 then
                local screenPos, onScreen = Camera:WorldToViewportPoint(part.Position)
                if onScreen then
                    if ExtraToggles.WallCheck and not isVisible(part) then continue end
                    local distToMouse = (Vector2.new(screenPos.X, screenPos.Y) - center).Magnitude
                    if distToMouse < minAngle then
                        if ExtraToggles.SilentPriority == "FOV" then
                            if distToMouse < bestValue then bestValue = distToMouse; targetPlayer = player end
                        elseif ExtraToggles.SilentPriority == "Distance" then
                            local dist3D = (Camera.CFrame.Position - part.Position).Magnitude
                            if dist3D < bestValue then bestValue = dist3D; targetPlayer = player end
                        elseif ExtraToggles.SilentPriority == "Health" then
                            if hum.Health < bestValue then bestValue = hum.Health; targetPlayer = player end
                        end
                    end
                end
            end
        end
    end

    SilentAimCache.targetPlayer = targetPlayer
    if targetPlayer and targetPlayer.Character then
        local hitChanceValid = true
        if ExtraToggles.SilentAimHitChance < 100 then
            hitChanceValid = math.random(1, 100) <= ExtraToggles.SilentAimHitChance
        end
        SilentAimCache.hitSuccess = hitChanceValid
        if hitChanceValid then
            SilentAimCache.hitPart = getTargetPart(targetPlayer.Character, false)
        else
            SilentAimCache.hitPart = nil
        end
    else
        SilentAimCache.hitPart = nil
        SilentAimCache.hitSuccess = false
    end
end

-- ========== Universal Silent Aim (Hook) ==========
local oldNamecall
oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
    local args = {...}
    local method = getnamecallmethod()
    if ExtraToggles.SilentAim and typeof(self) == "Instance" and self:IsA("Mouse") then
        if method == "Hit" or method == "Target" then
            if SilentAimCache.targetPlayer and SilentAimCache.hitPart and SilentAimCache.hitSuccess then
                if method == "Hit" then
                    return SilentAimCache.hitPart.CFrame
                elseif method == "Target" then
                    return SilentAimCache.hitPart
                end
            end
        end
    end
    return oldNamecall(self, ...)
end)


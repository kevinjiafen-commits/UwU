                    s.SoundId = HitSoundIDs[ExtraToggles.HitSoundType] or HitSoundIDs.Rust
                    s.Volume = ExtraToggles.HitSoundVolume
                    s:Play()
                    Debris:AddItem(s, 2)
                end
                EnemyHealths[player] = currentHealth
            end
        end
    end
end


		marker.AlwaysOnTop = true
		local triangle = Instance.new("ImageLabel", marker)
		triangle.Size = UDim2.new(1,0,1,0)
		triangle.BackgroundTransparency = 1
		triangle.Image = "rbxassetid://0"
		triangle.ImageColor3 = Color3.fromRGB(255,0,0)
		marker.Parent = LocalPlayer.PlayerGui
		ExtraConnections.Marker = RunService.RenderStepped:Connect(function()
			local target = nil
			local minAngle = 50
			local mousePos = UserInputService:GetMouseLocation()
			for _, player in ipairs(Players:GetPlayers()) do
				if player ~= LocalPlayer and player.Character then
					if ExtraToggles.AimbotTeamCheck and player.Team == LocalPlayer.Team then continue end
					local part = getHRP(player)
					if part then
						local screenPos = Camera:WorldToViewportPoint(part.Position)
						if screenPos.Z > 0 then
							local dx = screenPos.X - mousePos.X
							local dy = screenPos.Y - mousePos.Y
							local angle = math.sqrt(dx^2 + dy^2)
							if angle < minAngle then
								minAngle = angle
								target = player
							end
						end
					end
				end
			end
			if target and target.Character then
				marker.Adornee = getHRP(target)
				marker.Enabled = true
			else
				marker.Enabled = false
			end
		end)
	else
		if ExtraConnections.Marker then ExtraConnections.Marker:Disconnect(); ExtraConnections.Marker = nil end
		if LocalPlayer.PlayerGui:FindFirstChild("TargetMarker") then LocalPlayer.PlayerGui.TargetMarker:Destroy() end
	end
